  // This is your Prisma schema file,
  // learn more about it in the docs: https://pris.ly/d/prisma-schema

  // Get a free hosted Postgres database in seconds: `npx create-db`

  generator client {
    provider = "prisma-client-js"
  }

  datasource db {
    provider = "mysql"
    url      = env("DATABASE_URL")
  }

  model Post {
    id          Int      @id @default(autoincrement())
    title       String
    content     String   @db.LongText
    thumbnail   String?
    published   Boolean  @default(true)

    publishedAt DateTime?   

    createdAt   DateTime @default(now())
    updatedAt   DateTime @updatedAt
  }

  model Guru {
    id        Int      @id @default(autoincrement())
    nama      String
    jabatan   String
    kelas     String
    foto      String?
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
  }

  model User {
    id       Int    @id @default(autoincrement())
    email    String @unique
    password String
    name     String
  }

  model Karya {
    id          Int      @id @default(autoincrement())
    judul       String
    deskripsi   String   @db.Text
    link        String?
    namaPembuat String
    kelas       String
    jurusan     String
    thumbnail   String?  // Upload gambar/thumbnail karya
    status      Status   @default(PENDING)
    keterangan  String?  // Alasan penolakan/keterangan tambahan
    createdAt   DateTime @default(now())
    updatedAt   DateTime @updatedAt
  }

  enum Status {
    PENDING
    DITOLAK
    DITERIMA
  }

  model Pengunjung {
    id        Int      @id @default(autoincrement())
    tipe      String   // "siswa" or "bukan_siswa"
    nama      String
    kelas     String?
    jurusan   String?
    tujuan    String?  @db.Text
    alesan    String?  @db.Text
    tanggal   String
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@map("pengunjung")
  }